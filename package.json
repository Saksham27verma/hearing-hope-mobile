{
  "name": "hearing-hope-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:apk": "eas build --platform android --profile preview",
    "build:apk:production": "eas build --platform android --profile production",
    "update:preview": "EAS_SKIP_AUTO_FINGERPRINT=1 eas update --channel preview --platform android --auto --non-interactive",
    "update:production": "EAS_SKIP_AUTO_FINGERPRINT=1 eas update --channel production --platform android --auto --non-interactive",
    "reinstall": "node scripts/reinstall-deps.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-device": "~7.0.0",
    "expo-linking": "~7.0.0",
    "expo-notifications": "~0.31.0",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~29.0.16",
    "@expo/vector-icons": "^14.1.0",
    "firebase": "^11.0.0",
    "lucide-react-native": "^1.7.0",
    "react-native-svg": "^15.15.4",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.4"
  }
}
