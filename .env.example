# =============================================================================
# DEPLOYED CRM (production / employee APK / EAS cloud builds)
# =============================================================================
# Use the same public HTTPS URL where your Next.js CRM is deployed.
# NOT your home/office IP. Employees’ phones cannot reach your LAN.
#
# Typical Vercel URL (see hearing-hope-crm/HOSTING_GUIDE.md):
#   EXPO_PUBLIC_CRM_URL=https://hearing-hope-crm.vercel.app
#
# If you use a custom domain:
#   EXPO_PUBLIC_CRM_URL=https://crm.yourdomain.com
#
# This value is also set in eas.json for preview/production builds; keep them
# in sync, OR override via Expo dashboard → Environment variables.
EXPO_PUBLIC_CRM_URL=https://hearing-hope-crm.vercel.app

# Optional: override EAS project ID (default is set in app.config.ts after `eas init`).
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Firebase (same web config as the CRM — safe to embed in client apps; rules protect data)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# =============================================================================
# LOCAL DEV ONLY (Expo on your machine — copy this block ideas into .env)
# =============================================================================
# Physical device on Wi‑Fi (replace with your Mac’s LAN IP):
#   EXPO_PUBLIC_CRM_URL=http://192.168.1.50:3000
# Android emulator hitting CRM on the same machine:
#   EXPO_PUBLIC_CRM_URL=http://10.0.2.2:3000
# iOS simulator:
#   EXPO_PUBLIC_CRM_URL=http://localhost:3000
